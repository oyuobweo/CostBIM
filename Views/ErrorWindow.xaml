<Window x:Class="CostBIM.Views.ErrorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CostBIM Error" Height="220" Width="430"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False">
    
    <Border CornerRadius="12" Background="#FFFFFF" BorderBrush="#E2E8F0" BorderThickness="1.5">
        <Border.Effect>
            <DropShadowEffect Color="#0F172A" BlurRadius="25" ShadowDepth="4" Opacity="0.12"/>
        </Border.Effect>
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Header with Title / Drag Handler -->
                <RowDefinition Height="*"/>    <!-- Scrollable Error message -->
                <RowDefinition Height="Auto"/> <!-- Bottom Buttons -->
            </Grid.RowDefinitions>
            
            <!-- Header Grid for Dragging -->
            <Grid Grid.Row="0" Background="Transparent" MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="❌" FontSize="18" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="CostBIM Error" Foreground="#EF4444" FontSize="14.5" FontWeight="Bold" VerticalAlignment="Center"/>
                </StackPanel>
                
                <!-- Close Button in Top-Right -->
                <Button Content="✕" HorizontalAlignment="Right" VerticalAlignment="Center"
                        Width="24" Height="24" FontSize="12" Foreground="#94A3B8" FontWeight="SemiBold" Cursor="Hand" Click="BtnClose_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="Transparent">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
            
            <!-- Message Body Area -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,12,0,16">
                <TextBlock x:Name="TxtErrorMessage" Foreground="#475569" FontSize="12.5" FontWeight="SemiBold" TextWrapping="Wrap" LineHeight="19" Text="에러가 발생했습니다."/>
            </ScrollViewer>
            
            <!-- Bottom Button Bar -->
            <Button Grid.Row="2" Content="닫기" Width="88" Height="34" HorizontalAlignment="Right" Click="BtnClose_Click" Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="#6366F1" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" TextBlock.Foreground="White" TextBlock.FontWeight="Bold" TextBlock.FontSize="12.5"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#4F46E5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Grid>
    </Border>
</Window>
