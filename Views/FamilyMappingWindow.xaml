<Window x:Class="CostBIM.Views.FamilyMappingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="패밀리 명칭 치환 및 프리셋 설정" 
        Height="550" Width="800"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize">

    <Window.Resources>
        <!-- Premium Button Style (Indigo Gradient) -->
        <Style x:Key="PremiumButtonStyle" TargetType="Button">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#6366F1" Offset="0"/>
                        <GradientStop Color="#4F46E5" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <Border.Effect>
                                <DropShadowEffect Color="#6366F1" BlurRadius="6" ShadowDepth="1" Opacity="0.25"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#818CF8" Offset="0"/>
                                            <GradientStop Color="#6366F1" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="border" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#6366F1" BlurRadius="10" ShadowDepth="1.5" Opacity="0.45"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#4338CA" Offset="0"/>
                                            <GradientStop Color="#3730A3" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Premium Border Button Style (Sage / Emerald for Import/Export) -->
        <Style x:Key="PremiumBorderButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="#475569"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="11.5"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#F1F5F9"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#94A3B8"/>
                                <Setter Property="Foreground" Value="#1E293B"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#E2E8F0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Plain Title Bar Button Style -->
        <Style x:Key="TitleBarCloseButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#94A3B8"/>
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" Width="{TemplateBinding Width}" Height="{TemplateBinding Height}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#EF4444"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Modern DataGrid Cell Design -->
        <Style TargetType="DataGridCell">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" SnapsToDevicePixels="True">
                            <ContentPresenter ContentTemplate="{TemplateBinding ContentTemplate}" Content="{TemplateBinding Content}" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#F1F5F9"/>
                    <Setter Property="Foreground" Value="#0F172A"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Window.Triggers>
        <EventTrigger RoutedEvent="FrameworkElement.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="RootBorder"
                                     Storyboard.TargetProperty="Opacity"
                                     From="0.0" To="1.0"
                                     Duration="0:0:0.35"
                                     DecelerationRatio="0.85"/>
                    <DoubleAnimation Storyboard.TargetName="RootTranslate"
                                     Storyboard.TargetProperty="Y"
                                     From="20.0" To="0.0"
                                     Duration="0:0:0.35"
                                     DecelerationRatio="0.85"/>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>

    <!-- Master Border with premium glassmorphism dark charcoal aesthetic -->
    <Border x:Name="RootBorder" BorderBrush="#334155" BorderThickness="1.5" CornerRadius="12" ClipToBounds="True" Opacity="0">
        <Border.Background>
            <SolidColorBrush Color="#1E293B"/> <!-- 무채색 다크 차콜 심플 배경 -->
        </Border.Background>
        <Border.RenderTransform>
            <TranslateTransform x:Name="RootTranslate" Y="20"/>
        </Border.RenderTransform>
        
        <Grid>
            <Grid.RowDefinitions>
                <!-- Title Bar -->
                <RowDefinition Height="40"/>
                <!-- Main Content -->
                <RowDefinition Height="*"/>
                <!-- Action Controls -->
                <RowDefinition Height="64"/>
            </Grid.RowDefinitions>

            <!-- 1) Premium Custom Title Bar (Draggable) -->
            <Border Grid.Row="0" Background="#111827" BorderBrush="#334155" BorderThickness="0,0,0,1" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid Margin="14,0,0,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <!-- C&B 건축적 로고의 미니멀 선형 라인 반영 -->
                        <Path Data="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5" 
                              Stroke="#818CF8" StrokeThickness="1.8" Fill="Transparent" 
                              Width="14" Height="14" Stretch="Uniform" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="패밀리 명칭 치환 및 프리셋 설정" Foreground="#F3F4F6" FontSize="12.5" FontWeight="Bold" VerticalAlignment="Center"/>
                    </StackPanel>
                    
                    <Button HorizontalAlignment="Right" Style="{StaticResource TitleBarCloseButtonStyle}" Content="✕" FontSize="12" Click="BtnClose_Click"/>
                </Grid>
            </Border>

            <!-- 2) Main Data Input Grid -->
            <Grid Grid.Row="1" Margin="16,16,16,8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 안내 멘트 -->
                <StackPanel Grid.Row="0" Margin="0,0,0,12">
                    <TextBlock Text="🧱 내보낼 기초 객체의 패밀리 이름을 원하는 한글/실무 명칭으로 변경하세요." Foreground="#9CA3AF" FontSize="11.5" TextWrapping="Wrap"/>
                    <TextBlock Text="※ 치환 명칭이 비어있는 경우, 원래 패밀리 명칭 그대로 내보냅니다." Foreground="#6B7280" FontSize="10.5" Margin="0,2,0,0"/>
                </StackPanel>

                <!-- DataGrid (Dark/Light Contrast Style) -->
                <Border Grid.Row="1" Background="#FFFFFF" BorderBrush="#334155" BorderThickness="1" CornerRadius="6" Padding="4">
                    <DataGrid x:Name="GridMapping" AutoGenerateColumns="False" CanUserAddRows="False"
                              HeadersVisibility="Column" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#E2E8F0"
                              Background="Transparent" BorderThickness="0" RowBackground="#FFFFFF" AlternatingRowBackground="#F8FAFC"
                              ColumnHeaderHeight="28" SelectionMode="Single">
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#F1F5F9"/>
                                <Setter Property="Foreground" Value="#475569"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="FontSize" Value="11.5"/>
                                <Setter Property="Padding" Value="8,4"/>
                                <Setter Property="BorderBrush" Value="#CBD5E1"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.Columns>
                            <!-- 카테고리 (수정 불가) -->
                            <DataGridTextColumn Header="카테고리" Binding="{Binding Category}" IsReadOnly="True" Width="90">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#64748B"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="FontSize" Value="11.5"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <!-- 기존 패밀리 이름 (수정 불가) -->
                            <DataGridTextColumn Header="기존 패밀리 명칭" Binding="{Binding OriginalFamily}" IsReadOnly="True" Width="200">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#1E293B"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="FontSize" Value="11.5"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <!-- 치환할 명칭 (수정 가능 - TextBox 바인딩) -->
                            <DataGridTemplateColumn Header="치환할 명칭 (수정 가능)" Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBox Text="{Binding RemappedFamily, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                                 Background="White" BorderBrush="#CBD5E1" BorderThickness="1" Padding="6,3" FontSize="11.5" VerticalContentAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- 📏 길이 합산 여부 토글 -->
                            <DataGridCheckBoxColumn Header="📏 길이 합산" Binding="{Binding IsLengthSumChecked, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="95">
                                <DataGridCheckBoxColumn.ElementStyle>
                                    <Style TargetType="CheckBox">
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridCheckBoxColumn.ElementStyle>
                                <DataGridCheckBoxColumn.EditingElementStyle>
                                    <Style TargetType="CheckBox">
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridCheckBoxColumn.EditingElementStyle>
                            </DataGridCheckBoxColumn>

                            <!-- 📐 면적 합산 여부 토글 -->
                            <DataGridCheckBoxColumn Header="📐 면적 합산" Binding="{Binding IsAreaSumChecked, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="95">
                                <DataGridCheckBoxColumn.ElementStyle>
                                    <Style TargetType="CheckBox">
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridCheckBoxColumn.ElementStyle>
                                <DataGridCheckBoxColumn.EditingElementStyle>
                                    <Style TargetType="CheckBox">
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridCheckBoxColumn.EditingElementStyle>
                            </DataGridCheckBoxColumn>

                            <!-- 📦 개수 합산 여부 토글 -->
                            <DataGridCheckBoxColumn Header="📦 개수 합산" Binding="{Binding IsCountSumChecked, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="95">
                                <DataGridCheckBoxColumn.ElementStyle>
                                    <Style TargetType="CheckBox">
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridCheckBoxColumn.ElementStyle>
                                <DataGridCheckBoxColumn.EditingElementStyle>
                                    <Style TargetType="CheckBox">
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridCheckBoxColumn.EditingElementStyle>
                            </DataGridCheckBoxColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </Grid>

            <!-- 3) Action Controls Footer Area -->
            <Border Grid.Row="2" Background="#111827" BorderBrush="#334155" BorderThickness="0,1,0,0" Padding="14">
                <Grid>
                    <!-- Left: Presets Management (Import / Export) -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                        <Button Style="{StaticResource PremiumBorderButtonStyle}" Content="📥 프리셋 가져오기" Click="BtnImportPreset_Click" Margin="0,0,8,0"/>
                        <Button Style="{StaticResource PremiumBorderButtonStyle}" Content="📤 프리셋 저장" Click="BtnExportPreset_Click"/>
                    </StackPanel>

                    <!-- Right: Apply and Cancel -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button Style="{StaticResource PremiumBorderButtonStyle}" Content="초기화" Click="BtnReset_Click" Margin="0,0,10,0"/>
                        <Button Style="{StaticResource PremiumButtonStyle}" Content="💾 적용 및 내보내기" Click="BtnApply_Click" Width="150" Padding="0,8"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
